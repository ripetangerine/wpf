<Window x:Class="StudentInfo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StudentInfo"
        mc:Ignorable="d"
        Title="학생정보등록" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <GroupBox Header="기본 정보" Grid.Row="0">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="이름: " FontSize="14" Grid.Row="0" Grid.Column="0" Margin="0, 5" VerticalAlignment="Center"/>
                <TextBox x:Name="txtName" FontSize="14" Grid.Row="0" Grid.Column="1" Margin="0, 5" VerticalAlignment="Center"/>
                <TextBlock Text="학번: " FontSize="14" Grid.Row="1" Grid.Column="0" Margin="0, 5" VerticalAlignment="Center"/>
                <TextBox x:Name="txtStudentId" FontSize="14" Grid.Row="1" Grid.Column="1" Margin="0, 5" VerticalAlignment="Center"/>
                <TextBlock Text="연락처: " FontSize="14" Grid.Row="2" Grid.Column="0" Margin="0, 5" VerticalAlignment="Center"/>
                <TextBox x:Name="txtPhone" FontSize="14" Grid.Row="2" Grid.Column="1" Margin="0, 5" VerticalAlignment="Center"/>
            </Grid>
        </GroupBox>
        <GroupBox Header="추가 정보" Grid.Row="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="학과: " FontSize="14" Grid.Row="0" Grid.Column="0" Margin="0, 5" VerticalAlignment="Center"/>
                <ComboBox x:Name="cmbDepartment" FontSize="14" Grid.Row="0" Grid.Column="1" Margin="0, 5" VerticalAlignment="Center" Height="30">
                    <ComboBoxItem Content="소프트웨어과"/>
                    <ComboBoxItem Content="디자인과"/>
                </ComboBox>
                <TextBlock Text="생년월일: " FontSize="14" Grid.Row="1" Grid.Column="0" Margin="0, 5" VerticalAlignment="Center"/>
                <DatePicker Grid.Row="1" Grid.Column="1" x:Name="dpBirthday" Height="30" Margin="0, 5"/>
            </Grid>
        </GroupBox> 
        <StackPanel Grid.Row="2" HorizontalAlignment="Center" Orientation="Horizontal">
            <Button Content="등록" Width="100" Height="35" Click="btnRegister_Click" FontSize="14" Margin="10"/>
            <Button Content="초기화" Width="100" Height="35" Click="btnReset_Click" FontSize="14" Margin="10"/>
        </StackPanel>
    </Grid>
</Window>
