<Window x:Class="ParkingManager.ParkingFeeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ParkingManager"
        mc:Ignorable="d"
        Title="주차요금" Height="250" Width="300">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="0,70,0,30">
            <!-- 10분, 1시간-->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Margin="0,0,0,10" Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="10분" Margin="0,0,15,0"/>
                <TextBox x:Name="txtFee10Min" Width="80" />
            </StackPanel>
            <StackPanel Grid.Row="1" Margin="0,0,0,10" Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="1시간" Margin="0,0,10,0"/>
                <TextBox x:Name="txtFee1Hour" Width="80" />
            </StackPanel>
        </Grid>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="확인" Width="80" Margin="5,0" Click="btnOK_Click"/>
            <Button Content="취소" Width="80" Margin="5,0" Click="btnCancle_Click"/>
        </StackPanel>
    </Grid>
</Window>
