<Window x:Class="ParkingManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ParkingManager"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="ParkingManager-다연아파트" Height="450" Width="800">
    <Grid Margin="20">
        <!-- 전체 3행으로 분리 -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- 행 안에 행을 나눔 : 그리드 만듬 -->
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Margin="0,0,0,10" Orientation="Horizontal">
                <DatePicker x:Name="dpDate" Width="130" VerticalAlignment="center" Margin="0,0,5,0"/>
                <Button Content="일일 정산" Width="Auto" MinWidth="80" Height="30" Margin="3" Click="btnDailySettle_Click"/>
                <Button Content="월별 정산" Width="80" Height="30" Margin="3" Click="btnMonthlySettle_Click"/>
                <Button Content="정기차량 등록" Width="Auto" MinWidth="80" Height="30" Margin="3"/>
                <Button Content="할인 코드 등록" Width="Auto" Height="30" Margin="3" Click="btnDiscount_Click"/>
                <Button Content="주차요금 설정" Width="Auto" Height="30" Margin="3" Click="btnFeeSetting_Click"/>
            </StackPanel>
            <StackPanel Grid.Row="1" Margin="0,0,0,10" Orientation="Horizontal">
                <DatePicker x:Name="dpDate2" Width="130" VerticalAlignment="center" Margin="0,0,5,0"/>
                <Button Content="기간별 정산" Width="80" Height="30" Margin="3" Click="btnSearch_Click"/>
            </StackPanel>
        </Grid>
        <GroupBox Grid.Row="1" Header="입차" Margin="0,5,0,5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,5,0,5">
                    <TextBlock Text="입차 차량번호" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="txtEntryCarNumber" Width="200" Height="28" FontSize="14" Margin="0,0,10,0"/>
                    <Button Content="검색" Width="60" Height="28" Margin="0,0,5,0"/>
                    <Button Content="입차" Width="60" Height="28" Margin="0,0,5,0" Click="btnEntry_Click"/>
                </StackPanel>
                <DataGrid Grid.Row="1" x:Name="dgEntryCars" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" Margin="0,5,0,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="순번" Binding="{Binding No}" Width="60"/>
                        <DataGridTextColumn Header="차량번호" Binding="{Binding No}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>
        <GroupBox Grid.Row="2" Header="미출차" FontSize="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,5,0,5">
                    <TextBlock Text="출차 차량번호" Width="Auto" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="txtCarNumber" Width="200" Height="28" FontSize="14" TextChanged="txtCarNumber_TextChanged"/>
                    <Button Content="검색" Height="28" Width="60" Margin="0,0,5,0" Click="btnSearch_Click"/>
                    <Button Content="출차" Height="28" Width="60" Margin="0,0,100,0"/>
                    <Button Content="역순 목록" Height="28" Width="60" Margin="0,0,5,0" Click="btnReverse_Click"/>
                    <Button Content="순차 목록" Height="28" Width="60" Margin="0,0,5,0" Click="btn_Click"/>
                    <Button Content="목록 저장" Height="28" Width="60" Margin="0,0,5,0" Click="btnSaveList_Click"/>
                </StackPanel>
                <DataGrid Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single" Margin="0,0,5,0" x:Name="dgUnsettledCars">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="순번" Binding="{Binding No}" Width="60"/>
                        <DataGridTextColumn Header="차량번호" Binding="{Binding CarNumber}" Width="120"/>
                        <DataGridTextColumn Header="입차시간" Binding="{Binding EntryTime, StringFormat=yyyy. MM. dd. HH:mm}" Width="140"/>
                        <DataGridTextColumn Header="출차시간" Binding="{Binding ExitTime, StringFormat=yyyy. MM. dd. HH:mm}" Width="140"/>
                        <DataGridTextColumn Header="주차요금" Binding="{Binding ParkingFee, StringFormat={}{0:N0}}" Width="120"/>
                        <DataGridTextColumn Header="할인코드" Binding="{Binding DiscountCode}" Width="120"/>
                        <DataGridTextColumn Header="비고" Binding="{Binding Note}" Width="60"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>
    </Grid>
</Window>
